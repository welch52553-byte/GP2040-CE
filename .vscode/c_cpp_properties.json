{
    "configurations": [
        {
            "name": "Pico (RP2040)",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/headers/**",
                "${workspaceFolder}/headers/addons/**",
                "${workspaceFolder}/headers/configs/**",
                "${workspaceFolder}/headers/drivers/**",
                "${workspaceFolder}/headers/gamepad/**",
                "${workspaceFolder}/headers/display/**",
                "${workspaceFolder}/headers/interfaces/**",
                "${workspaceFolder}/lib/**",
                "${workspaceFolder}/configs/Pico",
                "${workspaceFolder}/configs/PicoMultiADC",
                "${workspaceFolder}/build/headers",
                "${workspaceFolder}/build/proto",
                "/opt/pico-sdk/src/rp2_common/**",
                "/opt/pico-sdk/src/rp2040/**",
                "/opt/pico-sdk/src/common/**",
                "/opt/pico-sdk/src/boards/include/**",
                "/opt/pico-sdk/lib/tinyusb/src/**",
                "/usr/lib/arm-none-eabi/include/**"
            ],
            "defines": [
                "PICO_BOARD=pico",
                "PICO_PLATFORM=rp2040",
                "GP2040_BOARDCONFIG=\"Pico\"",
                "LIB_PICO_STDIO_USB",
                "CFG_TUSB_MCU=OPT_MCU_RP2040",
                "PICO_RP2040=1"
            ],
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}
