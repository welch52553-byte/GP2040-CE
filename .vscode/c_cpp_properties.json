{
    "configurations": [
        {
            "name": "Pico (RP2040)",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/headers/**",
                "${workspaceFolder}/lib/**",
                "${workspaceFolder}/configs/Pico",
                "${workspaceFolder}/configs/PicoMultiADC",
                "${workspaceFolder}/build/headers",
                "${workspaceFolder}/build/proto"
            ],
            "defines": [
                "PICO_BOARD=pico",
                "PICO_PLATFORM=rp2040",
                "GP2040_BOARDCONFIG=\"Pico\"",
                "LIB_PICO_STDIO_USB",
                "CFG_TUSB_MCU=OPT_MCU_RP2040",
                "PICO_RP2040=1"
            ],
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}
